{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Polaris",
  "colors": {
    "primary": "#0D63F3",
    "light": "#7BC3FF",
    "dark": "#1349C5"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "pages": [
      {
        "group": "Start Here",
        "pages": [
          "index",
          "quickstart",
          "guides/connect",
          "guides/choose-the-right-data"
        ]
      },
      {
        "group": "Access Data",
        "expanded": false,
        "pages": [
          "reference/api-reference",
          "reference/authentication",
          "reference/catalog",
          "reference/snapshots",
          "reference/trades-api",
          "reference/events-api",
          "reference/ohlcv-api",
          "reference/raw-api"
        ]
      },
      {
        "group": "Schemas",
        "expanded": false,
        "pages": [
          "schemas/standardised-formats",
          "schemas/trades",
          "schemas/market-events",
          "schemas/ohlcv",
          "schemas/raw-payloads"
        ]
      },
      {
        "group": "SDKs",
        "expanded": false,
        "pages": [
          "sdks/python",
          "sdks/rust"
        ]
      },
      {
        "group": "Markets",
        "expanded": false,
        "pages": [
          "markets/market-coverage"
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "CLI",
          "href": "https://github.com/polaris-data/cli",
          "icon": "terminal"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:hello@polaris.supply"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open Polaris",
      "href": "https://polaris.supply"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/polaris_supply",
      "github": "https://github.com/polaris-data/cli"
    }
  }
}
