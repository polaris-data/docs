{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Polaris",
  "colors": {
    "primary": "#0D63F3",
    "light": "#7BC3FF",
    "dark": "#1349C5"
  },
  "background": {
    "color": {
      "dark": "#0D0D0D"
    }
  },
  "favicon": "/favicon.svg",
  "api": {
    "mdx": {
      "server": "https://api.polaris.supply"
    },
    "playground": {
      "display": "interactive"
    },
    "params": {
      "expanded": "closed"
    },
    "url": "full",
    "examples": {
      "languages": [
        "curl",
        "python",
        "javascript"
      ],
      "defaults": "required",
      "prefill": true,
      "autogenerate": true
    }
  },
  "navigation": {
    "pages": [
      {
        "group": "Getting Started",
        "pages": [
          "index",
          "quickstart",
          "guides/authentication",
          "reference/standardised-formats",
          "markets/market-coverage"
        ]
      },
      {
        "group": "SDKs",
        "pages": [
          "sdks/python",
          "sdks/typescript",
          "sdks/rust"
        ]
      },
      {
        "group": "Reference",
        "pages": [
          {
            "group": "API Reference",
            "pages": [
              "reference/api-reference",
              "reference/catalog",
              "reference/snapshots",
              "reference/download"
            ]
          },
          {
            "group": "Schema Reference",
            "pages": [
              "sdks/events",
              "sdks/ohlcv",
              "sdks/trades"
            ]
          }
        ]
      },
      {
        "group": "Resources",
        "expanded": false,
        "pages": [
          "guides/jupyter-notebook-quickstart"
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Account",
          "href": "https://polaris.supply/account",
          "icon": "user"
        },
        {
          "anchor": "CLI",
          "href": "https://github.com/polaris-data/cli",
          "icon": "terminal"
        },
        {
          "anchor": "LLMS.txt",
          "href": "/llms.txt",
          "icon": "file-text"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "https://t.me/hilliamt"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get an API Key",
      "href": "https://polaris.supply/account"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/polaris_supply",
      "github": "https://github.com/polaris-data/cli"
    }
  }
}
