{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Polaris",
  "colors": {
    "primary": "#171717",
    "light": "#171717",
    "dark": "#E5E5E5"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "pages": [
      {
        "group": "Overview",
        "pages": [
          "index",
          "quickstart"
        ]
      },
      {
        "group": "Guides",
        "pages": [
          "guides/getting-started",
          "guides/connect"
        ]
      },
      {
        "group": "Reference",
        "pages": [
          "reference/api-reference",
          "reference/catalog",
          "reference/snapshots"
        ]
      },
      {
        "group": "Schemas",
        "pages": [
          "schemas/standardised-formats",
          "schemas/trades",
          "schemas/market-events",
          "schemas/ohlcv",
          "schemas/raw-payloads"
        ]
      },
      {
        "group": "SDKs",
        "pages": [
          "sdks/python",
          "sdks/rust"
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "API base",
          "href": "https://api.polaris.supply",
          "icon": "globe"
        },
        {
          "anchor": "Status",
          "href": "https://status.polaris.supply",
          "icon": "activity"
        },
        {
          "anchor": "CLI",
          "href": "https://github.com/polaris-data/cli",
          "icon": "terminal"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Status",
        "href": "https://status.polaris.supply"
      },
      {
        "label": "Support",
        "href": "mailto:hello@polaris.supply"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open Polaris",
      "href": "https://polaris.supply"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/polaris_supply",
      "github": "https://github.com/polaris-data/cli"
    }
  }
}
